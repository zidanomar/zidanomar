---
interface ContactLink {
    label: string;
    value: string;
    href: string;
    external?: boolean;
}

interface Props {
    contacts: ContactLink[];
}

const { contacts } = Astro.props;
---
<section id="contact" class="section section--contact">
    <div class="section-inner">
        <h2 class="section-heading">contact</h2>

        <div class="terminal-prompt tl-reveal">
            <span class="prompt-sigil">›</span>
            <span class="prompt-text">open to new opportunities</span>
            <span class="prompt-cursor" aria-hidden="true">_</span>
        </div>

        <div class="contact-links">
            {contacts.map((contact, i) => (
                <a
                    href={contact.href}
                    class="contact-item tl-reveal"
                    target={contact.external ? "_blank" : undefined}
                    rel={contact.external ? "noopener" : undefined}
                >
                    <span class="item-fill" aria-hidden="true"></span>
                    <span class="item-index">0{i + 1}</span>
                    <span class="item-label">{contact.label}</span>
                    <span class="item-dots" aria-hidden="true"></span>
                    <span class="item-value">{contact.value}</span>
                    <span class="item-arrow" aria-hidden="true">↗</span>
                </a>
            ))}
        </div>

    </div>
</section>

<style>
.section--contact {
    border-top: 1px solid var(--border-color);
}

/* ── Terminal prompt ── */
.terminal-prompt {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    font-size: 0.875rem;
}

.prompt-sigil {
    color: var(--accent-color);
    font-size: 1rem;
    line-height: 1;
}

.prompt-text {
    color: var(--text-secondary);
    letter-spacing: 0.02em;
}

.prompt-cursor {
    color: var(--accent-color);
    animation: blink 1.1s step-end infinite;
}

@keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
}

/* ── Contact links ── */
.contact-links {
    display: flex;
    flex-direction: column;
    margin-bottom: 3rem;
}

.contact-item {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 1rem 0.5rem;
    border-bottom: 1px solid var(--border-color);
    text-decoration: none;
    color: var(--text-primary);
    overflow: hidden;
}

.contact-item:first-child {
    border-top: 1px solid var(--border-color);
}

/* Sliding fill on hover */
.item-fill {
    position: absolute;
    inset: 0;
    background: var(--bg-secondary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
    z-index: 0;
}

.contact-item:hover .item-fill {
    transform: scaleX(1);
}

.item-index {
    position: relative;
    z-index: 1;
    font-size: 0.65rem;
    color: var(--accent-color);
    letter-spacing: 0.08em;
    flex-shrink: 0;
    transition: color 0.2s ease;
    min-width: 2ch;
}

.item-label {
    position: relative;
    z-index: 1;
    font-size: 0.7rem;
    color: var(--text-secondary);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    flex-shrink: 0;
    min-width: 5ch;
    transition: color 0.2s ease;
}

/* Dot leader */
.item-dots {
    position: relative;
    z-index: 1;
    flex: 1;
    border-bottom: 1px dotted var(--border-color);
    margin-bottom: 0.2em;
    min-width: 1rem;
    transition: border-color 0.2s ease;
}

.contact-item:hover .item-dots {
    border-color: var(--text-secondary);
}

.item-value {
    position: relative;
    z-index: 1;
    font-size: 0.8rem;
    color: var(--text-primary);
    flex-shrink: 0;
    transition: color 0.2s ease;
}

.contact-item:hover .item-value {
    color: var(--text-accent);
}

.item-arrow {
    position: relative;
    z-index: 1;
    font-size: 0.8rem;
    color: var(--accent-color);
    opacity: 0;
    transform: translate(-4px, 2px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    flex-shrink: 0;
}

.contact-item:hover .item-arrow {
    opacity: 1;
    transform: translate(0, 0);
}


@media (max-width: 768px) {
    .item-value { font-size: 0.75rem; }
    .item-arrow { opacity: 1; transform: none; }
    .contact-item { gap: 0.5rem; }
}
</style>
