<nav class="section-nav" aria-label="Sections">
    <a href="#home"       class="dot" data-section="home"       title="Home"></a>
    <a href="#experience" class="dot" data-section="experience" title="Experience"></a>
    <a href="#contact"    class="dot" data-section="contact"    title="Contact"></a>
</nav>

<style>
.section-nav {
    position: fixed;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 10px;
    z-index: 100;
}

.dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--border-color);
    display: block;
    transition: background 0.2s ease, transform 0.2s ease;
}

@media (max-width: 768px) {
    .section-nav { display: none; }
}
</style>
